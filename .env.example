# Sanity CMS (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=

# Sanity read token — required for draft/preview mode, optional otherwise
SANITY_API_READ_TOKEN=

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA4_ID=

# Resend — transactional emails for contact form (optional)
RESEND_API_KEY=

# MailerLite — newsletter subscriptions (optional)
MAILERLITE_API_KEY=

# MailerLite group IDs — one per lead magnet (optional)
MAILERLITE_GROUP_GENERAL=
MAILERLITE_GROUP_HIRING_CHECKLIST=
MAILERLITE_GROUP_ROI_CALCULATOR=
MAILERLITE_GROUP_PERFORMANCE_ASSESSMENT=
MAILERLITE_GROUP_BLOG_WAITLIST=
